---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { PassionScroll } from "../components/PassionScroll";
import { TextImageBlock } from "../components/TextImageBlock";
import QuoteBlock from "../components/QuoteBlock.astro";
import { HeroHeader } from "../components/HeroHeader";
import heroImg from "../assets/image/about_hero.png";
import img1 from "../assets/image/image-import-11.jpg";
import img2 from "../assets/image/image-import-25.jpg";
import { ActionSection } from "../components/Action";
import { EventsSection } from "../components/Events";
import Container from "../components/Container.astro";
---

<Layout>
  <Navbar />
  <HeroHeader
    client:load
    label='ESOA Brussels'
    title='Académie'
    imageSrc={img1.src}
    imageAlt='ESOA Brussels académie'
  />
  <!-- Texte gauche, image droite -->
  <TextImageBlock
    client:load
    label='Notre philosophie'
    title={"Notre vision\ndu football"}
    imageSrc={img1.src}
    imageAlt='Football académie'
    paragraphs={[
      "L'académie ESOA Brussels est née d'une conviction simple : chaque jeune talent mérite un encadrement de haut niveau, quelle que soit son origine. Nos entraîneurs certifiés accompagnent chaque joueur dans sa progression technique, mentale et collective.",
      "Nos séances combinent des exercices spécifiques élite, des sessions vidéo et un suivi personnalisé pour révéler le plein potentiel de chaque joueur. Rejoignez une structure qui place l'humain au cœur du développement sportif.",
    ]}
  />

  <QuoteBlock
    quote='"Le football ne forge pas seulement des joueurs — il forge des caractères, des leaders et des hommes."'
    author='ESOA Brussels'
  />

  <!-- Image gauche, texte droite -->
  <TextImageBlock
    client:load
    label='Rejoignez-nous'
    title={"Faire partie\nde l'aventure"}
    imageSrc={img2.src}
    imageAlt='Joueurs ESOA'
    reverse={true}
    paragraphs={[
      "ESOA Brussels, c'est bien plus qu'une académie de football. C'est une communauté de joueurs, parents et entraîneurs qui partagent la même passion et les mêmes ambitions.",
      "Tournois internationaux, stages de formation, matchs amicaux — chaque événement est une opportunité de grandir ensemble et de vivre des moments inoubliables sur et en dehors du terrain.",
    ]}
  />

  <PassionScroll client:load />
  <section class='bg-[#EFF2F6] py-16 px-4 sm:px-6'>
    <div class='max-w-287.5 mx-auto flex flex-col gap-6'>
      <!-- Label -->
      <div class='flex items-center gap-2.5'>
        <!-- Actions sociales icon -->
        <svg
          class='h-[67px] w-[67px]'
          viewBox='0 0 87 87'
          fill='none'
          xmlns='http://www.w3.org/2000/svg'>
