            fill='black'></path>
        </svg>

        <span
          class='bebas-neue-regular text-[32px] lg:text-[64px] font-semibold uppercase text-black'>
          Actions sociales
        </span>
      </div>

      <!-- Card -->
      <div
        class='relative w-full rounded-2xl overflow-hidden'
        style='height: clamp(360px, 45vw, 520px)'>
        <!-- Background image -->
        <img
          src={heroImg.src}
          alt='Une académie, une communauté'
          class='absolute inset-0 w-full h-full object-cover object-center'
        />

        <!-- Gradient overlay left → transparent -->
        <div
          class='absolute inset-0'
          style='background: linear-gradient(90deg, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.40) 50%, rgba(0,0,0,0.05) 100%)'>
        </div>

        <!-- Text content -->
        <div class='absolute inset-0 flex flex-col justify-end p-8 sm:p-10'>
          <h2
            class='bebas-neue-regular text-white leading-none mb-3'
            style='font-size: clamp(3rem, 5vw, 6rem)'>
            Une académie,<br />une communauté
          </h2>
          <p
            class='inter text-white/75 text-base sm:text-xl max-w-md leading-relaxed'>
            Joueurs, parents, entraîneurs — nous avançons ensemble. Suivez notre
            quotidien, célébrez nos victoires et faites partie de l'aventure sur
            nos réseaux sociaux.
          </p>
        </div>
      </div>
    </div>
  </section>
  <ActionSection client:load />
  <section class='py-[72px]'>
    <Container>
      <h2 class='text-4xl font-bold mb-12'>Nos évènements</h2>
      <EventsSection client:load />
    </Container>
  </section>
  <Footer />
</Layout>
