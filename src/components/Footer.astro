---
import Container from "./Container.astro";
import icons from "../assets/icons.svg";
---

<footer class="bg-[#EFF2F6]">
  <Container>
    <!-- Top row: logo + nav + (empty right) -->
    <div class="flex flex-col sm:flex-row items-center sm:items-center justify-between gap-6 py-10">

      <!-- Logo -->
      <a href="/" aria-label="Accueil ESOA">
        <img src={icons.src} alt="Logo ESOA" class="w-14" />
      </a>

      <!-- Nav links -->
      <nav class="flex flex-wrap items-center justify-center gap-6 sm:gap-8">
        <a href="/blog" class="footer-link">Blog</a>
        <a href="/academie" class="footer-link">Explorer</a>
        <a href="#" class="footer-link">En savoir plus</a>
        <a href="/academie" class="footer-link">À propos</a>
      </nav>

      <!-- Espace réservé pour équilibrer -->
      <div class="w-14 hidden sm:block"></div>
    </div>

    <!-- Divider -->
    <div class="border-t border-black/10"></div>

    <!-- Bottom row: copyright + social -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 py-6">
      <p class="inter text-xs text-black/50">
        © {new Date().getFullYear()} ESOA Brussels. Tous droits réservés.
      </p>

      <!-- Social icons -->
      <div class="flex items-center gap-4">
        <!-- Facebook -->
        <a href="#" aria-label="Facebook" class="social-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <!-- LinkedIn -->
        <a href="#" aria-label="LinkedIn" class="social-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
        <!-- Twitter / X -->
        <a href="#" aria-label="Twitter" class="social-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M4 4l16 16M4 20L20 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
          </svg>
        </a>
      </div>
    </div>
  </Container>
</footer>

<style>
  .footer-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    color: #000;
    text-decoration: none;
    transition: color 0.2s;
    letter-spacing: 0.03em;
  }

  .footer-link:hover {
    color: #f97316;
  }

  .social-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #d1d9e6;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1a1a2e;
    transition: background 0.2s, color 0.2s;
    text-decoration: none;
  }

  .social-icon:hover {
    background: #f97316;
    color: white;
  }
</style>
